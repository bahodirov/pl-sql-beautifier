{
  "name": "plsql-beautifier",
  "displayName": "PL/SQL Beautifier",
  "description": "Format PL/SQL / SQL code using PL/SQL Developer-compatible beautifier settings",
  "version": "0.1.7",
  "publisher": "Dilshod",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bahodirov/pl-sql-beautifier"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "keywords": ["plsql", "sql", "oracle", "formatter", "beautifier"],
  "activationEvents": [
    "onLanguage:sql",
    "onLanguage:plsql",
    "onLanguage:oraclesql",
    "onLanguage:oracle-sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "plsqlBeautifier.formatDocument",
        "title": "Format PL/SQL Document",
        "category": "PL/SQL Beautifier"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "plsqlBeautifier.formatDocument",
          "when": "editorLangId == sql || editorLangId == plsql || editorLangId == oraclesql || editorLangId == oracle-sql"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.0.0"
  }
}
